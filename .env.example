# Copy this file to .env and fill in your keys
# Never commit .env to git

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs — get voice IDs from elevenlabs.io/voice-library
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_A_ID=your_host_a_voice_id_here    # Host A: expert explainer
ELEVENLABS_VOICE_B_ID=your_host_b_voice_id_here    # Host B: curious generalist

# Semantic Scholar (optional — works without it at lower rate limits)
# Get a key at semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

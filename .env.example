# Copy this file to .env and fill in your keys
# Never commit .env to git

# Anthropic (Claude) — platform key pool
# Use _1, _2, ... for multiple keys (round-robin distribution). Falls back to no-suffix key.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_API_KEY_1=key_one_here
# ANTHROPIC_API_KEY_2=key_two_here

# OpenAI TTS + LLM (used when VOICE_PROVIDER=openai or LLM_PROVIDER_*=openai)
# Same multi-key convention applies: OPENAI_API_KEY_1, _2, ... for pool distribution
OPENAI_API_KEY=your_openai_api_key_here

# Voice provider: openai | elevenlabs | google (default: openai)
VOICE_PROVIDER=openai

# Product mode: personal | commercial (default: personal)
PRODUCT_MODE=personal

# ElevenLabs — get voice IDs from elevenlabs.io/voice-library
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_A_ID=your_host_a_voice_id_here    # Host A: expert explainer
ELEVENLABS_VOICE_B_ID=your_host_b_voice_id_here    # Host B: curious generalist

# Semantic Scholar (optional — works without it at lower rate limits)
# Get a key at semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex / Unpaywall / Crossref — your email enables polite pool (higher rate limits)
# Required in commercial mode: Unpaywall skips license resolution without it
OPENALEX_EMAIL=your_email@example.com

# Springer and IEEE (optional — those sources are skipped if not set)
SPRINGER_API_KEY=
IEEE_API_KEY=

# Neon Postgres — DATABASE_URL uses pooler; DATABASE_URL_DIRECT for migrations
DATABASE_URL=postgresql://user:pass@pooler.neon.tech/paperspod?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@host.neon.tech/paperspod?sslmode=require

# Cloudflare R2 object storage (optional — episodes still work without it)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=paperspod-episodes

# BYOK encryption — generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Set via: fly secrets set ENCRYPTION_KEY=<output>  — never commit the value
ENCRYPTION_KEY=your_fernet_key_here

# Clerk auth (optional locally — omit CLERK_JWKS_URL to skip JWT verification)
# Format: https://<your-clerk-domain>/.well-known/jwks.json
CLERK_JWKS_URL=

# Admin user allowlist — comma-separated Clerk user IDs (sub claim) that can access /admin
# Find your user ID in the Clerk dashboard under Users > click user > User ID
# Also set this as ADMIN_USER_IDS in your Vercel environment variables for the frontend
ADMIN_USER_IDS=user_your_clerk_user_id_here

# LLM provider routing — per stage: anthropic | openai | gemini (default: anthropic for all)
# Tier (cheap/standard/premium) is derived from curation_level automatically.
LLM_PROVIDER_SCRIPT=anthropic
LLM_PROVIDER_BIBLIOGRAPHY=anthropic
LLM_PROVIDER_REASONING=anthropic
LLM_PROVIDER_GRAPH=anthropic

# Google Gemini (required when any LLM_PROVIDER_* = gemini)
# GOOGLE_API_KEY=your_google_api_key_here
